# Database (PostgreSQL). For Railway: use DATABASE_URL from dashboard.
DATABASE_URL=postgresql://user:password@localhost:5432/toss

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Skip AI moderation (set to 1 in dev to make items go live immediately)
SKIP_MODERATION=1

# Allowed email domains for signup (comma-separated). Leave unset to allow any email.
# ALLOWED_EMAIL_DOMAINS=sfu.ca,ubc.ca

# Firebase (optional until you add Firebase Auth)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Stripe (optional until you add card on file / charges)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Google Gemini for item moderation and wishlist matching (optional)
# GEMINI_API_KEY=

# Google Maps for neighbourhoods (optional)
# GOOGLE_MAPS_API_KEY=
