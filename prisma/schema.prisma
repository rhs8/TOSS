// Toss: Community Exchange Platform
// Rules: list before receive, 1 exchange/week, 6-month commitment, card on file for abuse

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  createdAt     DateTime @default(now())
  commitmentEnd DateTime // 6-month minimum from first listing
  cardOnFile    Boolean  @default(false) // placeholder for Stripe; charge if abuse
  listings      Listing[]
  received      Exchange[] @relation("Receiver")
  lent          Exchange[] @relation("Lender")
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String?  // e.g. "tools", "kitchen", "furniture"
  imageUrl    String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  isActive    Boolean  @default(true) // false when currently lent out
  exchanges   Exchange[]
}

model Exchange {
  id            String   @id @default(cuid())
  listingId     String
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  receiverId    String
  receiver      User     @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  lenderId      String
  lender        User     @relation("Lender", fields: [lenderId], references: [id], onDelete: Cascade)
  weekStart     DateTime // week window (one exchange per user per week)
  status        String   @default("active") // active | returned | disputed | charged
  borrowedAt    DateTime @default(now())
  dueReturnAt   DateTime?
  returnedAt    DateTime?
}
